APP_NAME=LLM Firewall Gateway & Ops Platform
# Production: use PostgreSQL. SQLite can still be used for local demo only.
DATABASE_URL=postgresql+psycopg://llm_firewall:change-me@localhost:5432/llm_firewall
TASK_QUEUE_BACKEND=arq
REDIS_URL=redis://localhost:6379/0
TASK_QUEUE_NAME=llm_firewall_tasks
TASK_TIMEOUT_SECONDS=300
TASK_MAX_RETRIES=3
RULE_FILE=data/rules/default_rules.yaml
MODEL_PATH=data/models/risk_classifier.joblib
REPORT_DIR=docs/reports
SCAN_API_KEY=replace-with-real-scan-key
ADMIN_API_KEY=replace-with-real-admin-key
JWT_SECRET_KEY=replace-with-real-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEFAULT_REVIEW_THRESHOLD=0.55
DEFAULT_BLOCK_THRESHOLD=0.80
MAX_USER_INPUT_CHARS=4000
MAX_CONTEXT_CHARS=8000
MAX_MODEL_OUTPUT_CHARS=8000
MAX_UPLOAD_BYTES=1048576
MAX_IMPORT_RECORDS=1000
MAX_EVAL_SAMPLES=300
MAX_STRATEGY_COUNT=8
MAX_EVAL_OPERATIONS=15000
MAX_SAMPLE_AUDIT_SAMPLES=400
MAX_SAMPLE_AUDIT_PAIRS=20000
STORAGE_PREVIEW_CHARS=512
PERSIST_MODEL_OUTPUT=false
# MODEL_SHA256=required-if-you-want-to-load-the-trained-classifier
MAX_RULE_COUNT=256
MAX_RULE_PATTERN_CHARS=300
LOG_LEVEL=INFO
